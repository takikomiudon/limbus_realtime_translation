# .env.example
# Local environment template. Copy to .env and replace placeholder values.
# Do not commit real API keys or service account credentials.

# Gemini API key used by main.py for translation.
GOOGLE_API_KEY=replace-with-your-gemini-api-key

# Google Cloud service account JSON path used by Speech-to-Text and Firestore.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Translation server endpoint used by main.py after each completed translation.
API_BASE_URL=http://localhost:8000/api/translations

# Shared API key required by server POST /api/translations.
API_KEY=change-me

# Firestore database used by the server repository.
FIRESTORE_DATABASE=limbus-realtime-translator

# Optional explicit project for Firestore. Required for emulator workflows.
GOOGLE_CLOUD_PROJECT=replace-with-your-gcp-project

# Optional server tuning values.
CORS_ORIGINS=*
MAX_REQUESTS_PER_SECOND=2
RATE_LIMIT_WINDOW_SECONDS=1
